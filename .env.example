# Environment Variables for NovaChem Industrial Knowledge Intelligence
# Copy this file to .env and fill in your values

# NVIDIA NIM API Key (required for vision pipeline)
# Get free tier key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Local Ollama endpoint (for agent layer LLM fallback)
# OLLAMA_HOST=http://localhost:11434

# Optional: ChromaDB settings (if using remote Chroma)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# Optional: NIM spacing override (seconds between requests, default 1.5)
# NIM_SPACING_SEC=1.5

# Optional: Vision pipeline model override
# NEMOTRON_MODEL=nvidia/nemotron-page-elements-v3